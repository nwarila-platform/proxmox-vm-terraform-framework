# ============================================================================ #
#  EditorConfig — Enforces consistent formatting across editors & contributors #
#  https://editorconfig.org                                                    #
# ============================================================================ #

root = true

# ---------------------------------------------------------------------------- #
#  Universal defaults                                                          #
# ---------------------------------------------------------------------------- #
[*]
charset                  = utf-8
end_of_line              = lf
indent_size              = 2
indent_style             = space
insert_final_newline     = true
max_line_length          = 98
trim_trailing_whitespace = true

# ---------------------------------------------------------------------------- #
#  Markdown                                                                    #
# ---------------------------------------------------------------------------- #
[*.md]
trim_trailing_whitespace = false
max_line_length          = off

# ---------------------------------------------------------------------------- #
#  Shell scripts                                                               #
# ---------------------------------------------------------------------------- #
[*.{sh,bash}]
shell_variant = bash

# ---------------------------------------------------------------------------- #
#  Makefiles (require tabs)                                                    #
# ---------------------------------------------------------------------------- #
[Makefile]
indent_style = tab
indent_size  = 4