# ------------------------------------------------------------------------------
# Multi-VM Example
# ------------------------------------------------------------------------------
# Deploys multiple VMs in a single apply — one per list entry.
# Demonstrates mixed configurations: a lightweight utility VM and a
# heavier workload VM with more resources and a dedicated EFI disk.
# Copy this file to terraform.tfvars and fill in your values.
# Never commit terraform.tfvars — it is excluded by .gitignore.
# ------------------------------------------------------------------------------

proxmox_hostname         = "10.0.0.10"
proxmox_api_token_id     = "terraform@pve!automation"
proxmox_api_token_secret = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
proxmox_skip_tls_verify  = true

all_systems = [

  # --------------------------------------------------------------------------
  # Lightweight utility VM
  # --------------------------------------------------------------------------
  {
    name      = "utility-01"
    node_name = "pve01"
    pool_id   = "homelab"
    template  = "debian-12-template"
    vm_id     = 201

    cpu = {
      cores = 1
      type  = "host"
    }

    memory = {
      dedicated = 512
    }

    disks = [
      {
        size         = 8
        datastore_id = "local-lvm"
        file_format  = "raw"
      }
    ]

    network_devices = [
      {
        bridge  = "vmbr0"
        model   = "virtio"
        vlan_id = 20
      }
    ]

    tags    = ["utility", "debian"]
    on_boot = true
    started = true
  },

  # --------------------------------------------------------------------------
  # Workload VM with EFI, TPM, QEMU guest agent, and static IP via cloud-init
  # --------------------------------------------------------------------------
  {
    name      = "workload-01"
    node_name = "pve01"
    pool_id   = "homelab"
    template  = "ubuntu-24.04-template"
    vm_id     = 202

    bios = "ovmf"

    cpu = {
      cores   = 4
      sockets = 1
      type    = "host"
    }

    memory = {
      dedicated = 8192
    }

    disks = [
      {
        size         = 64
        datastore_id = "nvme-pool"
        file_format  = "raw"
        iothread     = true
        aio          = "io_uring"
      }
    ]

    efi_disk = {
      datastore_id = "nvme-pool"
      file_format  = "raw"
      type         = "4m"
    }

    tpm_state = {
      datastore_id = "nvme-pool"
      version      = "v2.0"
    }

    network_devices = [
      {
        bridge      = "vmbr0"
        model       = "virtio"
        vlan_id     = 10
        ipv4_address = "10.0.10.50/24"
        ipv4_gateway = "10.0.10.1"
      }
    ]

    agent = {
      enabled = true
      timeout = "5m"
    }

    startup = {
      order      = 2
      up_delay   = 10
      down_delay = 10
    }

    tags    = ["workload", "ubuntu", "production"]
    on_boot = true
    started = true
  }
]
