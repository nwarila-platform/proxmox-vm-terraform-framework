# ------------------------------------------------------------------------------
# Single VM Example
# ------------------------------------------------------------------------------
# Deploys one VM cloned from an existing Proxmox template.
# Copy this file to terraform.tfvars and fill in your values.
# Never commit terraform.tfvars — it is excluded by .gitignore.
# ------------------------------------------------------------------------------

proxmox_hostname         = "10.0.0.10"
proxmox_api_token_id     = "terraform@pve!automation"
proxmox_api_token_secret = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
proxmox_skip_tls_verify  = true

all_systems = [
  {
    name      = "example-vm-01"
    node_name = "pve01"
    pool_id   = "homelab"
    template  = "ubuntu-24.04-template"
    vm_id     = 200

    cpu = {
      cores   = 2
      sockets = 1
      type    = "host"
    }

    memory = {
      dedicated = 2048
    }

    disks = [
      {
        size         = 32
        datastore_id = "local-lvm"
        file_format  = "raw"
      }
    ]

    network_devices = [
      {
        bridge  = "vmbr0"
        model   = "virtio"
        vlan_id = 10
      }
    ]

    agent = {
      enabled = true
    }

    tags     = ["example", "ubuntu"]
    on_boot  = true
    started  = true
  }
]
