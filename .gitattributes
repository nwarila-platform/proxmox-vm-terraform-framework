#%   A '.gitattributes' file defines per-path attributes that control how Git handles files.  %#
#%   This file enforces consistent line endings, configures diff drivers, registers GitHub    %#
#%   Linguist overrides for accurate language detection, and controls what is included in     %#
#%   release archives (git archive / GitHub releases).                                        %#
#%                                                                                            %#
#% ADDITIONAL INFORMATION                                                                     %#
#%   Official Git Documentation: https://git-scm.com/docs/gitattributes                      %#
#%                                                                                            %#
#endregion --- [ Header ] -------------------------------------------------------------------- #

# -------------------------------------------------------------------------- #
#  Global default — normalize all text files to LF on commit                 #
#  eol=lf enforced cross-platform (Linux CI + Windows self-hosted runners)   #
# -------------------------------------------------------------------------- #
* text=auto eol=lf

# -------------------------------------------------------------------------- #
#  Terraform & HCL                                                            #
# -------------------------------------------------------------------------- #
*.tf            text eol=lf diff=terraform
*.tfvars        text eol=lf diff=terraform
*.tfvars.example text eol=lf diff=terraform
*.hcl           text eol=lf diff=terraform

# -------------------------------------------------------------------------- #
#  YAML — GitHub Actions, workflows, devcontainer, linter configs            #
# -------------------------------------------------------------------------- #
*.yaml          text eol=lf diff=yaml
*.yml           text eol=lf diff=yaml

# -------------------------------------------------------------------------- #
#  Markdown                                                                   #
# -------------------------------------------------------------------------- #
*.md            text eol=lf diff=markdown

# -------------------------------------------------------------------------- #
#  JSON — VSCode settings, release-please, markdownlint                      #
# -------------------------------------------------------------------------- #
*.json          text eol=lf

# -------------------------------------------------------------------------- #
#  Python — requirements files                                                #
# -------------------------------------------------------------------------- #
*.py            text eol=lf
*.txt           text eol=lf

# -------------------------------------------------------------------------- #
#  Shell — inline bash used in composite actions                              #
# -------------------------------------------------------------------------- #
*.sh            text eol=lf

# -------------------------------------------------------------------------- #
#  PowerShell — inline pwsh used in Windows composite action                 #
#  Note: pwsh handles LF natively; CRLF not required                         #
# -------------------------------------------------------------------------- #
*.ps1           text eol=lf

# -------------------------------------------------------------------------- #
#  Keepfiles                                                                  #
# -------------------------------------------------------------------------- #
.gitkeep        text eol=lf

# -------------------------------------------------------------------------- #
#  Merge strategy                                                             #
#  CHANGELOG.md is managed by release-please — union prevents write conflicts#
# -------------------------------------------------------------------------- #
CHANGELOG.md    merge=union

# -------------------------------------------------------------------------- #
#  GitHub Linguist — language detection overrides                            #
#  Without these, YAML and Markdown volume skews repo language stats         #
# -------------------------------------------------------------------------- #

# Primary language: HCL (Terraform)
*.tf            linguist-language=HCL linguist-detectable=true
*.hcl           linguist-language=HCL linguist-detectable=true
*.tfvars        linguist-language=HCL linguist-detectable=true
*.tfvars.example linguist-language=HCL linguist-detectable=true

# Classify documentation as non-code for language stats
docs/           linguist-documentation=true
*.md            linguist-documentation=true

# Classify CI/CD infrastructure and tooling as non-primary
.github/        linguist-generated=false linguist-detectable=false
.config/        linguist-detectable=false
.devcontainer/  linguist-detectable=false
.vscode/        linguist-detectable=false
requirements/   linguist-detectable=false

# -------------------------------------------------------------------------- #
#  Export-ignore — excluded from git archive and GitHub release tarballs     #
#  Consumers of this framework only need terraform/ and examples/            #
# -------------------------------------------------------------------------- #
.config/                    export-ignore
.devcontainer/              export-ignore
.github/                    export-ignore
.vscode/                    export-ignore
.gitattributes              export-ignore
.gitignore                  export-ignore
.pre-commit.config.yaml     export-ignore
docs/                       export-ignore
mkdocs.yml                  export-ignore
requirements/               export-ignore
release-please-config.json  export-ignore
.release-please-manifest.json export-ignore
CHANGELOG.md                export-ignore
CODE_OF_CONDUCT.md          export-ignore
CONTRIBUTING.md             export-ignore
SECURITY.md                 export-ignore
SUPPORT.md                  export-ignore
