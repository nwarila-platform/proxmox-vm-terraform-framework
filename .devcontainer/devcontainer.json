{
  "name": "proxmox-vm-terraform-framework",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": true,
      "installOhMyZsh": true,
      "upgradePackages": true
    },
    "ghcr.io/devcontainers/features/git:1": {
      "ppa": true,
      "version": "latest"
    },
    "ghcr.io/devcontainers-contrib/features/terraform-asdf:2": {
      "version": "1.15.2"
    },
    "ghcr.io/devcontainers-contrib/features/tflint:1": {
      // renovate: datasource=github-releases depName=terraform-linters/tflint extractVersion=^v(?<version>.*)$
      "version": "0.62.0"
    },
    "ghcr.io/devcontainers-contrib/features/trivy:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers-contrib/features/terraform-docs:1": {
      "version": "0.23.0"
    },
    "ghcr.io/rocker-org/devcontainer-features/apt-packages:1": {
      "packages": "python3-pip,python3-venv"
    }
  },
  "postCreateCommand": "pip3 install --user -r requirements/devcontainer.txt && pre-commit install --hook-type pre-commit --hook-type pre-push --hook-type commit-msg",
  "customizations": {
    "vscode": {
      "extensions": [
        "hashicorp.terraform",
        "hashicorp.hcl",
        "redhat.vscode-yaml",
        "zokugun.explicit-folding",
        "codezombiech.gitignore",
        "davidanson.vscode-markdownlint",
        "signageos.signageos-vscode-sops"
      ],
      "settings": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.renderWhitespace": "all",
        "files.eol": "\n",
        "terraform.languageServer.enable": true
      }
    }
  },
  "remoteUser": "vscode"
}
